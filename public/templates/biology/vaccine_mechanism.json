{
  "id": "vaccine_mechanism",
  "domain": "biology",
  "title": "How Vaccines Work",
  "description": "See how vaccination trains your immune system to defeat a pathogen before it ever infects you.",
  "maxTicks": 2400,
  "ticksPerSecond": 60,
  "parameters": {
    "vaccinated_fraction": { "type": "float", "min": 0.0, "max": 1.0, "default": 0.7, "step": 0.1, "label": "Vaccination Rate", "description": "Fraction of population vaccinated" },
    "pathogen_count": { "type": "int", "min": 10, "max": 60, "default": 30, "step": 5, "label": "Pathogen Load", "description": "Incoming pathogen count" }
  },
  "visualConfig": {
    "person_unaware": { "shape": "circle", "radius": 10, "color": "#475569", "borderColor": "#334155", "borderStyle": "solid" },
    "person_immune": { "shape": "circle", "radius": 10, "color": "#6366F1", "borderColor": "#4F46E5", "borderStyle": "solid", "glowColor": "#6366F1", "glowIntensity": 0.3 },
    "person_spreading": { "shape": "circle", "radius": 10, "color": "#EF4444", "borderColor": "#DC2626", "borderStyle": "solid", "glowColor": "#EF4444", "glowIntensity": 0.5 },
    "virus": { "shape": "triangle", "radius": 5, "color": "#F97316", "borderColor": "#EA580C", "borderStyle": "solid", "glowColor": "#F97316", "glowIntensity": 0.4 }
  },
  "rules": [
    {
      "id": "pathogen_infects_unvaccinated",
      "conditions": [
        { "type": "entity_has_tag", "tag": "pathogen" },
        { "type": "neighbor_within", "distance": 25, "state": "unaware" },
        { "type": "random_chance", "probability": 0.04 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "bind", "color": "#F97316" }
      ],
      "priority": 1,
      "cooldownTicks": 20
    },
    {
      "id": "vaccinated_repels_pathogen",
      "conditions": [
        { "type": "entity_has_tag", "tag": "vaccinated" },
        { "type": "neighbor_within", "distance": 22, "tag": "pathogen" },
        { "type": "random_chance", "probability": 0.25 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "deflect", "color": "#6366F1" }
      ],
      "priority": 1,
      "cooldownTicks": 10
    }
  ],
  "initialSpawn": [
    { "entityType": "person_immune", "countFormula": "Math.round(60 * vaccinated_fraction)", "distribution": "random", "tags": ["vaccinated"] },
    { "entityType": "person_unaware", "countFormula": "Math.round(60 * (1 - vaccinated_fraction))", "distribution": "random", "tags": ["unvaccinated"] },
    { "entityType": "virus", "countFormula": "pathogen_count", "distribution": "random", "tags": ["pathogen"] }
  ],
  "narration": [
    { "tick": 0, "text": "Purple individuals are vaccinated. Their immune systems have already learned to recognise this pathogen. Grey individuals are unprotected." },
    { "tick": 200, "text": "Pathogens encounter vaccinated individuals — their antibodies neutralise the threat immediately. No infection. No illness." },
    { "tick": 400, "text": "Unvaccinated individuals are vulnerable. But notice — pathogens reaching them must first pass through the vaccinated buffer." },
    { "tick": 700, "text": "Herd immunity at work: vaccinated individuals don't just protect themselves — they form barriers that prevent pathogens from reaching the unvaccinated." },
    { "tick": 1200, "text": "Adjust the vaccination rate with the slider. At 70%, many are protected. At 30%, pathogens move freely. The threshold matters." },
    { "tick": 1800, "text": "Vaccination works by training the immune system using a harmless piece of the pathogen — a preview that prepares your defences before the real threat arrives." }
  ]
}
