{
  "id": "office_secret_leak",
  "domain": "social",
  "title": "How a Secret Leaks in an Office",
  "description": "Why 'tell no one' always fails — the information theory of workplace secrets and trust networks.",
  "maxTicks": 1800,
  "ticksPerSecond": 60,
  "parameters": {
    "office_size": { "type": "int", "min": 15, "max": 60, "default": 30, "step": 3, "label": "Office Size", "description": "Number of employees" },
    "trust_level": { "type": "float", "min": 0.1, "max": 0.9, "default": 0.5, "step": 0.05, "label": "Average Trust", "description": "How much employees trust each other (higher = faster leaking)" },
    "gossip_hubs": { "type": "int", "min": 0, "max": 4, "default": 2, "step": 1, "label": "Office Gossips", "description": "High-connectivity individuals who spread information quickly" }
  },
  "visualConfig": {
    "person_unaware": { "shape": "circle", "radius": 10, "color": "#475569", "borderColor": "#334155", "borderStyle": "solid" },
    "person_heard": { "shape": "circle", "radius": 10, "color": "#F59E0B", "borderColor": "#D97706", "borderStyle": "solid", "glowColor": "#F59E0B", "glowIntensity": 0.3 },
    "person_spreading": { "shape": "circle", "radius": 10, "color": "#EF4444", "borderColor": "#DC2626", "borderStyle": "solid", "glowColor": "#EF4444", "glowIntensity": 0.4 },
    "person_dismissed": { "shape": "circle", "radius": 10, "color": "#22C55E", "borderColor": "#16A34A", "borderStyle": "solid" },
    "person_immune": { "shape": "circle", "radius": 16, "color": "#F97316", "borderColor": "#EA580C", "borderStyle": "solid", "glowColor": "#F97316", "glowIntensity": 0.7 }
  },
  "rules": [
    {
      "id": "secret_spreads_between_trusted",
      "conditions": [
        { "type": "entity_state", "state": "spreading" },
        { "type": "neighbor_within", "distance": 50, "state": "unaware" },
        { "type": "random_chance", "probability": 0.03 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "SET_STATE", "entityId": "__self__", "state": "heard" },
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "whisper", "color": "#F59E0B" }
      ],
      "priority": 1,
      "cooldownTicks": 35
    },
    {
      "id": "gossip_hub_amplifies",
      "conditions": [
        { "type": "entity_state", "state": "spreading" },
        { "type": "entity_has_tag", "tag": "hub" },
        { "type": "neighbor_within", "distance": 90, "state": "unaware" },
        { "type": "random_chance", "probability": 0.07 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "spread", "color": "#F97316" }
      ],
      "priority": 1,
      "cooldownTicks": 15
    },
    {
      "id": "heard_decides_to_tell",
      "conditions": [
        { "type": "entity_state", "state": "heard" },
        { "type": "ticks_in_state_gt", "ticks": 40 },
        { "type": "random_chance", "probability": 0.6 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "SET_STATE", "entityId": "__self__", "state": "spreading" }
      ],
      "priority": 2,
      "cooldownTicks": 0
    },
    {
      "id": "discreet_person_keeps_it",
      "conditions": [
        { "type": "entity_state", "state": "heard" },
        { "type": "entity_has_tag", "tag": "discreet" },
        { "type": "ticks_in_state_gt", "ticks": 30 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "SET_STATE", "entityId": "__self__", "state": "dismissed" }
      ],
      "priority": 2,
      "cooldownTicks": 0
    }
  ],
  "initialSpawn": [
    { "entityType": "person_spreading", "countFormula": "1", "distribution": "clustered", "tags": ["origin"] },
    { "entityType": "person_immune", "countFormula": "gossip_hubs", "distribution": "random", "tags": ["hub"] },
    { "entityType": "person_dismissed", "countFormula": "Math.round(office_size * 0.15)", "distribution": "random", "tags": ["discreet"] },
    { "entityType": "person_unaware", "countFormula": "office_size - gossip_hubs - Math.round(office_size * 0.15) - 1", "distribution": "random", "tags": [] }
  ],
  "narration": [
    { "tick": 0, "text": "One person knows a secret. They tell just one trusted colleague — 'just between us'. The leak begins." },
    { "tick": 200, "text": "Information theory: sharing a secret with N people means trusting all N to keep it, plus all their trusted contacts." },
    { "tick": 500, "text": "Orange gossip hubs — high-connectivity individuals — are accelerating the spread enormously. They're not malicious. They're just well-connected." },
    { "tick": 800, "text": "Green individuals are discreet — they heard it but won't pass it on. In every office, these are the people worth trusting. They're rare." },
    { "tick": 1200, "text": "The secret has reached over half the office. The person who shared it 'in confidence' has no idea how far it's travelled." },
    { "tick": 1600, "text": "The only truly safe secret is one never spoken. Every additional person multiplies the network of potential leaks exponentially — not additively." }
  ]
}
