{
  "id": "social_movement",
  "domain": "social",
  "title": "Social Movement Ignition",
  "description": "From spark to wildfire — how a small committed group triggers a cascade that changes society.",
  "maxTicks": 2400,
  "ticksPerSecond": 60,
  "parameters": {
    "population": { "type": "int", "min": 60, "max": 150, "default": 100, "step": 10, "label": "Population" },
    "core_activists": { "type": "int", "min": 2, "max": 15, "default": 5, "step": 1, "label": "Core Activists", "description": "Small committed group who start the movement" },
    "grievance_level": { "type": "float", "min": 0.2, "max": 0.9, "default": 0.6, "step": 0.05, "label": "Grievance Level", "description": "How strongly people feel the underlying issue — determines receptiveness" }
  },
  "visualConfig": {
    "person_unaware": { "shape": "circle", "radius": 9, "color": "#475569", "borderColor": "#334155", "borderStyle": "solid" },
    "person_heard": { "shape": "circle", "radius": 9, "color": "#F59E0B", "borderColor": "#D97706", "borderStyle": "solid", "glowColor": "#F59E0B", "glowIntensity": 0.3 },
    "person_spreading": { "shape": "circle", "radius": 10, "color": "#EF4444", "borderColor": "#DC2626", "borderStyle": "solid", "glowColor": "#EF4444", "glowIntensity": 0.5 },
    "person_dismissed": { "shape": "circle", "radius": 9, "color": "#94A3B8", "borderColor": "#64748B", "borderStyle": "solid" },
    "person_immune": { "shape": "circle", "radius": 11, "color": "#A855F7", "borderColor": "#7C3AED", "borderStyle": "solid", "glowColor": "#A855F7", "glowIntensity": 0.7 }
  },
  "rules": [
    {
      "id": "activist_recruits",
      "conditions": [
        { "type": "entity_state", "state": "spreading" },
        { "type": "entity_has_tag", "tag": "activist" },
        { "type": "neighbor_within", "distance": 65, "state": "unaware" },
        { "type": "random_chance", "probability": 0.04 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "SET_STATE", "entityId": "__self__", "state": "heard" },
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "signal", "color": "#A855F7" }
      ],
      "priority": 1,
      "cooldownTicks": 25
    },
    {
      "id": "movement_reaches_critical_mass",
      "conditions": [
        { "type": "entity_state", "state": "heard" },
        { "type": "neighbor_within", "distance": 55, "state": "spreading" },
        { "type": "ticks_in_state_gt", "ticks": 50 },
        { "type": "random_chance", "probability": 0.045 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "SET_STATE", "entityId": "__self__", "state": "spreading" },
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "spread", "color": "#EF4444" }
      ],
      "priority": 2,
      "cooldownTicks": 0
    },
    {
      "id": "opposition_resists",
      "conditions": [
        { "type": "entity_state", "state": "unaware" },
        { "type": "entity_has_tag", "tag": "opposed" },
        { "type": "neighbor_within", "distance": 40, "state": "spreading" },
        { "type": "ticks_in_state_gt", "ticks": 30 }
      ],
      "conditionLogic": "AND",
      "mutations": [
        { "type": "SET_STATE", "entityId": "__self__", "state": "dismissed" },
        { "type": "EMIT_PARTICLE", "position": { "x": 0, "y": 0 }, "effect": "deflect", "color": "#94A3B8" }
      ],
      "priority": 1,
      "cooldownTicks": 0
    }
  ],
  "initialSpawn": [
    { "entityType": "person_immune", "countFormula": "core_activists", "distribution": "clustered", "tags": ["activist"] },
    { "entityType": "person_dismissed", "countFormula": "Math.round(population * 0.15)", "distribution": "random", "tags": ["opposed"] },
    { "entityType": "person_unaware", "countFormula": "population - core_activists - Math.round(population * 0.15)", "distribution": "random", "tags": [] }
  ],
  "narration": [
    { "tick": 0, "text": "5 core activists (purple) in a population of 100. Everyone else is unaware. Most social movements in history started with a group this small or smaller." },
    { "tick": 300, "text": "Activists work outward from their core. Early recruitment is slow — people are risk-averse and await social proof before joining." },
    { "tick": 700, "text": "Critical mass approaching. Once enough people have joined, the social cost of not joining begins to exceed the cost of joining. The cascade tips." },
    { "tick": 1100, "text": "The movement is growing faster than activists can account for. Ordinary people — not organisers — are now the primary recruiters." },
    { "tick": 1600, "text": "Grey individuals (opposed) are resisting and creating counter-clusters. Movements always generate opposition — the question is which cascade is faster." },
    { "tick": 2100, "text": "Erica Chenoweth's research: nonviolent movements that mobilise 3.5% of the population have never failed to achieve major political change. Every mass movement started with fewer than 5 people." }
  ]
}
